{
  "consumer": {
    "name": "notification-service"
  },
  "provider": {
    "name": "product-service"
  },
  "interactions": [
    {
      "description": "a GET request for product 10 detail",
      "providerStates": [
        {
          "name": "product 10 exists"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/v1/products/10"
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "data": {
            "id": 10,
            "name": "Smart Fitness Watch",
            "sku": "ELEC-010",
            "price": 179.99
          },
          "traceId": "pact-product-trace-001"
        },
        "matchingRules": {
          "body": {
            "$.data.id": {
              "matchers": [{"match": "type"}],
              "combine": "AND"
            },
            "$.data.name": {
              "matchers": [{"match": "type"}],
              "combine": "AND"
            },
            "$.data.sku": {
              "matchers": [{"match": "type"}],
              "combine": "AND"
            },
            "$.data.price": {
              "matchers": [{"match": "type"}],
              "combine": "AND"
            },
            "$.traceId": {
              "matchers": [{"match": "type"}],
              "combine": "AND"
            }
          }
        }
      }
    }
  ],
  "metadata": {
    "pactSpecification": {
      "version": "3.0.0"
    },
    "pact-jvm": {
      "version": "4.6.17"
    }
  }
}
