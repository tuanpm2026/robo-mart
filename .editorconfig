# EditorConfig - https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.java]
indent_style = space
indent_size = 4

[*.{yml,yaml,json,js,ts,vue,html,css,scss}]
indent_style = space
indent_size = 2

[*.xml]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{sh,bash}]
indent_style = space
indent_size = 2

[*.{avsc,avdl}]
indent_style = space
indent_size = 2

[*.proto]
indent_style = space
indent_size = 2
